# Anthropic
ANTHROPIC_API_KEY=

# ── Government databases ──────────────────────────────────────
# USASpending    → no key needed  https://api.usaspending.gov
# CMS NPI        → no key needed  https://npiregistry.cms.hhs.gov/api
# OpenCorporates → no key needed  https://api.opencorporates.com/v0.4/companies/search
# EDGAR (SEC)    → no key needed  https://efts.sec.gov/LATEST/search-index
#                  (User-Agent header required to avoid throttling — already set in fetch_edgar)

# SAM.gov → free key, ~2 min: sam.gov/profile/details → Account Details → Public API Key
SAM_API_KEY=

# OpenSanctions → free for non-commercial use, 30-day trial: opensanctions.org/api/
OPENSANCTIONS_API_KEY=

# Slack (only needed for stretch goal bot)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=

# Web app URL exposed via ngrok (used by Slack bot to generate watch links)
WEB_APP_URL=https://your-ngrok-url.ngrok.io

# Web app: URL of the Slack bot's SSE server (for live session streaming)
VITE_SLACK_BOT_URL=http://localhost:3001

# Optional: bake API key into web build (dev only — never commit a real key)
VITE_ANTHROPIC_API_KEY=
